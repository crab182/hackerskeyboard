# ============================================================================
# diyRAG — environment template  (copy to `.env`, then fill in real values)
# ============================================================================
# 12-factor config (MASTER_BUILD_SPEC.md §19). Every value here is a SAFE
# PLACEHOLDER. NO REAL SECRETS GO IN THIS FILE OR IN `.env` COMMITTED TO GIT.
# Production secrets are delivered via Docker secrets / SOPS-encrypted env /
# Vault (§12.1, §12.8). `.env` is gitignored; `.env.example` is the only one
# committed.
#
# Variables are grouped by concern/service. The Rust `common::config` crate
# reads these (env overrides typed defaults). Hosts use docker-compose service
# names; override for bare-metal / unraid as needed.
# ============================================================================


# ----------------------------------------------------------------------------
# GLOBAL / RUNTIME
# ----------------------------------------------------------------------------
# Deployment environment: development | staging | production
DIYRAG_ENV=development
# Log level: trace | debug | info | warn | error
RUST_LOG=info,diyrag=debug
# Log format: json (prod/observability) | pretty (local dev)
DIYRAG_LOG_FORMAT=json


# ----------------------------------------------------------------------------
# DATA DIRECTORIES (platform-specific; §16b.2 Windows / §16b.3 unraid)
# ----------------------------------------------------------------------------
# Windows Service stores state under %ProgramData%\diyRAG (restricted ACLs).
#   DIYRAG_DATA_DIR=C:\ProgramData\diyRAG
# unraid stores state under the appdata share.
#   DIYRAG_DATA_DIR=/mnt/user/appdata/diyrag
DIYRAG_DATA_DIR=/mnt/user/appdata/diyrag
# Subpaths derived from DIYRAG_DATA_DIR unless overridden:
DIYRAG_CONFIG_DIR=${DIYRAG_DATA_DIR}/config
DIYRAG_MODEL_CACHE_DIR=${DIYRAG_DATA_DIR}/model-cache
DIYRAG_CERTS_DIR=${DIYRAG_DATA_DIR}/certs


# ----------------------------------------------------------------------------
# POSTGRES 16 — authoritative metadata (§5.1, sqlx)
# ----------------------------------------------------------------------------
POSTGRES_USER=diyrag
POSTGRES_PASSWORD=CHANGE_ME_postgres_password   # PLACEHOLDER — use a secret
POSTGRES_DB=diyrag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# sqlx connection string (sslmode=require once mTLS/PKI is in place — §12.1)
DATABASE_URL=postgres://diyrag:CHANGE_ME_postgres_password@postgres:5432/diyrag
DATABASE_MAX_CONNECTIONS=20


# ----------------------------------------------------------------------------
# QDRANT — vector store, per-tenant collections (§5.2)
# ----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_GRPC_URL=http://qdrant:6334
QDRANT_API_KEY=CHANGE_ME_qdrant_api_key         # PLACEHOLDER (empty in dev OK)
# Collection naming: t_{tenant_slug}; named vectors dense+sparse (§5.2)
QDRANT_VECTOR_DENSE_SIZE=1024                    # BGE-M3 dense dim
QDRANT_QUANTIZATION=scalar                       # scalar | binary | none


# ----------------------------------------------------------------------------
# NATS JETSTREAM — async ingestion broker (§3.2, §6.2)
# ----------------------------------------------------------------------------
NATS_URL=nats://nats:4222
NATS_STREAM=diyrag-ingestion
# Subjects: separate priority queues so queries are not starved (§15)
NATS_SUBJECT_INGEST=ingest.work
NATS_SUBJECT_INGEST_PRIORITY=ingest.priority
NATS_SUBJECT_SYNC=sync.events
NATS_CONSUMER_DURABLE=ingestion-workers
NATS_MAX_DELIVER=5                               # → DLQ after N (§14)


# ----------------------------------------------------------------------------
# OBJECT STORE / BLOB — content-addressed retention (§5.3, object_store crate)
# ----------------------------------------------------------------------------
# Backend: minio | s3 | azure | gcs | local
OBJECT_STORE_BACKEND=minio
OBJECT_STORE_BUCKET=diyrag-blobs
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_REGION=us-east-1
# MinIO / S3 credentials — PLACEHOLDERS, deliver via Docker secrets in prod
OBJECT_STORE_ACCESS_KEY=CHANGE_ME_minio_access_key
OBJECT_STORE_SECRET_KEY=CHANGE_ME_minio_secret_key
OBJECT_STORE_FORCE_PATH_STYLE=true               # required for MinIO
# MinIO server root creds (used by the minio container itself)
MINIO_ROOT_USER=CHANGE_ME_minio_root_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password


# ----------------------------------------------------------------------------
# REDIS — distributed rate-limit buckets + answer/embedding cache (§12.3, §15)
# ----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_redis_password          # PLACEHOLDER (empty in dev OK)


# ----------------------------------------------------------------------------
# OBSERVABILITY — OTLP / Prometheus / Loki / Tempo (§13)
# ----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=diyrag
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0                       # sample 100% in dev
# Correlation-id propagation header (generated at gateway, §13.1)
DIYRAG_CORRELATION_HEADER=X-Correlation-ID


# ----------------------------------------------------------------------------
# AUTH — JWT / OAuth 2.1 / API keys (§12.2)
# ----------------------------------------------------------------------------
# OAuth 2.1 / OIDC issuer the gateway & MCP server trust (§8, §12.2)
OAUTH_ISSUER_URL=https://idp.lan.example/realms/diyrag
OAUTH_AUDIENCE=diyrag-api
OAUTH_JWKS_URL=https://idp.lan.example/realms/diyrag/protocol/openid-connect/certs
# JWT signing/verification secret for locally-issued tokens — PLACEHOLDER.
# Use an asymmetric key pair (RS256/ES256) in production; never commit it.
JWT_SECRET=CHANGE_ME_jwt_hs256_secret_min_32_chars
JWT_ALG=HS256
JWT_ACCESS_TTL_SECONDS=3600
# API keys are stored only as argon2 hashes (§12.2). This pepper hardens them.
API_KEY_ARGON2_PEPPER=CHANGE_ME_argon2_pepper    # PLACEHOLDER


# ----------------------------------------------------------------------------
# GATEWAY — CORS, request limits, rate limiting (§12.3, §11)
# ----------------------------------------------------------------------------
GATEWAY_BIND_ADDR=0.0.0.0:8443
GATEWAY_TLS_CERT_PATH=${DIYRAG_CERTS_DIR}/gateway.crt
GATEWAY_TLS_KEY_PATH=${DIYRAG_CERTS_DIR}/gateway.key
# CORS allow-list (comma-separated origins). MCP browser clients need this (§8)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.lan.example
CORS_ALLOW_CREDENTIALS=true
# Body / multipart caps (§12.3)
MAX_REQUEST_BODY_BYTES=10485760                   # 10 MiB JSON
MAX_UPLOAD_BYTES=1073741824                       # 1 GiB upload
# Rate-limit knobs — per source IP and per API key (§12.3)
RATE_LIMIT_PER_IP_RPS=20
RATE_LIMIT_PER_IP_BURST=40
RATE_LIMIT_PER_KEY_RPS=50
RATE_LIMIT_PER_KEY_BURST=100
# Stricter limits on expensive endpoints (ingest/sync/answer)
RATE_LIMIT_ANSWER_RPS=5
RATE_LIMIT_INGEST_RPS=10


# ----------------------------------------------------------------------------
# INFERENCE BACKEND SELECTOR (§16, §24.1)
# ----------------------------------------------------------------------------
# Embedding backend: rust-native (candle) | gpu-runtime (Python)
EMBED_BACKEND=rust-native
EMBED_MODEL=BAAI/bge-m3
RERANK_BACKEND=rust-native
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Local model directories for the in-proc candle backends (ADR-0009). Each must
# contain config.json + tokenizer.json + model.safetensors. NO Hub download at
# runtime (offline / LAN-only default). Unset → the service boots but errors
# clearly if embedding/reranking is attempted.
DIYRAG_EMBED_MODEL_DIR=${DIYRAG_MODEL_CACHE_DIR}/bge-m3
DIYRAG_RERANK_MODEL_DIR=${DIYRAG_MODEL_CACHE_DIR}/bge-reranker-v2-m3
# LLM backend / profile: rust-llm (mistral.rs) | py-llm (vLLM) | api-llm
LLM_BACKEND=rust-llm
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# gpu-runtime endpoint (used when *_BACKEND=gpu-runtime/py-llm)
GPU_RUNTIME_URL=http://gpu-runtime:50051
# parsing-service endpoint (hard parses / OCR — §6.3)
PARSING_SERVICE_URL=http://parsing-service:50052


# ----------------------------------------------------------------------------
# GPU / CUDA TOGGLES (§16)
# ----------------------------------------------------------------------------
# candle device for the in-proc embed/rerank backends: cpu | cuda | metal
# (ADR-0009). DECISION: CPU is the portable default so every node — including the
# Windows service and unraid — builds and boots. CUDA/Metal are opt-in candle
# cargo features baked into a GPU build of the image; there is NO DirectML path
# (candle does not support it — AMD/Intel Windows GPUs fall back to CPU or use the
# Python gpu-runtime). No ONNX Runtime / libonnxruntime to provision.
DIYRAG_CANDLE_DEVICE=cpu
# NVIDIA Container Toolkit passthrough (docker-compose.gpu.yml)
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
CUDA_VISIBLE_DEVICES=0
# Dynamic embed batch sizing (§6.5); falls back to CPU on OOM/thermal (§14)
EMBED_BATCH_SIZE=32
EMBED_MAX_BATCH_SIZE=128


# ----------------------------------------------------------------------------
# CHUNKING & RETRIEVAL DEFAULTS (§6.4, §7.1)
# ----------------------------------------------------------------------------
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CHUNK_HARD_MAX_TOKENS=1024
RETRIEVAL_TOP_K0=40            # candidates before rerank
RETRIEVAL_TOP_K=10            # kept after rerank
RETRIEVAL_FUSION=rrf          # rrf | weighted


# ----------------------------------------------------------------------------
# LAN SYNC — node identity, peers, PKI (§9, §16b.4)
# ----------------------------------------------------------------------------
SYNC_NODE_ID=node-a                               # unique per LAN instance
SYNC_NODE_NAME=homelab-primary
SYNC_NODE_PRIORITY=100                             # conflict tiebreak (§9)
SYNC_BIND_ADDR=0.0.0.0:7443                        # tonic gRPC + mTLS
# mDNS discovery + static peer fallback (comma-separated host:port)
SYNC_MDNS_ENABLED=true
SYNC_STATIC_PEERS=node-b.lan:7443,node-c.lan:7443
# Internal CA / mTLS material (rcgen-issued; §12.1). Keys never committed.
SYNC_CA_CERT_PATH=${DIYRAG_CERTS_DIR}/ca.crt
SYNC_NODE_CERT_PATH=${DIYRAG_CERTS_DIR}/node.crt
SYNC_NODE_KEY_PATH=${DIYRAG_CERTS_DIR}/node.key
SYNC_RATE_LIMIT_RPS=10                              # DoS guard on sync (§9)


# ----------------------------------------------------------------------------
# diyragd SUPERVISOR & WINDOWS SERVICE (§16b)
# ----------------------------------------------------------------------------
# Run mode: all-in-one | agent | service:<name>
DIYRAGD_MODE=all-in-one
# ingestion-worker concurrency (Linux replicas / Windows task count)
DIYRAGD_WORKER_MIN=1
DIYRAGD_WORKER_MAX=8
# Windows-only: the dedicated low-privilege service account (§16b.2, §12.8).
# Prefer the managed virtual account; do NOT run as LocalSystem unless GPU
# access requires it (documented trade-off).
WINDOWS_SERVICE_ACCOUNT=NT SERVICE\diyRAG
WINDOWS_SERVICE_NAME=diyRAG
WINDOWS_EVENTLOG_SOURCE=diyRAG


# ----------------------------------------------------------------------------
# REMINDER
# ----------------------------------------------------------------------------
# Every CHANGE_ME_* above is a placeholder. Real values come from Docker
# secrets / SOPS / Vault and must never be committed. (§12.1, §12.8)
